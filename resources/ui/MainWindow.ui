}

QWidget#page3DView QFrame#card3DSurfaces QLabel,
QWidget#page3DView QFrame#card3DElectrodes QLabel,
QWidget#page3DView QFrame#card3DSlices QLabel,
QWidget#page3DView QFrame#card3DMRI QLabel,
QWidget#page3DView QFrame#card3DCT QLabel,
QWidget#page3DView QFrame#card3DPET QLabel,
