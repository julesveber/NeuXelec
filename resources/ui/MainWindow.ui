<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Form</class>
 <widget class="QWidget" name="Form">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1290</width>
    <height>746</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>NeuXelec – Multimodal Electrode Hub</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* ==============================================================
   NeuXelec – Main Window Theme
   Keeps every existing objectName and signal/slot target intact.
   ============================================================== */
QWidget#Form {
    background-color: #06070D;
    color: #F2F2F5;
    font-family: &quot;Segoe UI&quot;, &quot;Arial&quot;;
    font-size: 12px;
}

QWidget, QFrame {
    color: #F2F2F5;
}

QFrame#frame, QFrame#frame_3, QStackedWidget#stackedWidget,
QWidget#pageFiles, QWidget#pageReconstruction,
QWidget#pageObliqueSlices, QWidget#page3DView, QWidget#pageSaveExport {
    background-color: transparent;
    border: none;
}

/* ---------- Left navigation rail ---------- */
QFrame#menu {
    background-color: #0B0D14;
    border: 1px solid #232633;
    border-radius: 18px;
}

QLabel#appTitle {
    color: #F4D9D0;
    font-size: 21px;
    font-weight: 600;
    letter-spacing: 2px;
    background: transparent;
    border: none;
}

QLabel#appSubtitle {
    color: #858896;
    font-size: 10px;
    letter-spacing: 1px;
    background: transparent;
    border: none;
    padding-bottom: 10px;
}

QFrame#frame_4 {
    background-color: #10121A;
    border: 1px solid #2B2D38;
    border-radius: 12px;
}

QFrame#frame_4 QLabel {
    color: #CFCFD6;
    font-size: 11px;
    font-weight: 600;
    background: transparent;
    border: none;
}

QLineEdit#le_menu_patientID {
    min-height: 35px;
    color: #F2F2F5;
    background-color: #151720;
    border: 1px solid #2B2D38;
    border-radius: 8px;
    padding: 0px 10px;
    selection-background-color: #FF487D;
}

QLineEdit#le_menu_patientID:focus {
    border: 1px solid #FF487D;
    background-color: #181A24;
}

QPushButton#btn_menu_fileCoreg,
QPushButton#btn_menu_reconstruction,
QPushButton#btn_menu_obliqueSlice,
QPushButton#btn_menu_3Dview {
    min-height: 48px;
    color: #D8DAE4;
    background-color: transparent;
    border: 1px solid transparent;
    border-radius: 11px;
    text-align: left;
    padding-left: 18px;
    font-size: 13px;
    font-weight: 600;
}

QPushButton#btn_menu_fileCoreg:hover,
QPushButton#btn_menu_reconstruction:hover,
QPushButton#btn_menu_obliqueSlice:hover,
QPushButton#btn_menu_3Dview:hover {
    color: white;
    background-color: #141620;
    border: 1px solid #FF487D;
}

QPushButton#btn_menu_fileCoreg:pressed,
QPushButton#btn_menu_reconstruction:pressed,
QPushButton#btn_menu_obliqueSlice:pressed,
QPushButton#btn_menu_3Dview:pressed {
    color: white;
    background-color: #141620;
    border: 1px solid #FF487D;
}

QPushButton#btn_menu_fileCoreg:checked,
QPushButton#btn_menu_reconstruction:checked,
QPushButton#btn_menu_obliqueSlice:checked,
QPushButton#btn_menu_3Dview:checked {
    color: white;
    background-color: #141620;
    border: 1px solid #FF487D;
}

/* ---------- Main content ---------- */
QFrame#frame_7, QFrame#frame_11, QFrame#frame_15 {
    background-color: #080A10;
    border: 1px solid #1D202B;
    border-radius: 15px;
}

QScrollArea {
    background-color: transparent;
    border: none;
}
QScrollArea &gt; QWidget &gt; QWidget {
    background-color: transparent;
}

QLabel {
    color: #CFCFD6;
    background-color: transparent;
    border: none;
}

/* Page/section titles already present in the .ui */
QLabel#label_20, QLabel#label_8, QLabel#label_25,
QLabel#label_5, QLabel#label_6,
QLabel#label_21, QLabel#label_23, QLabel#label_24, QLabel#label_28,
QLabel#label_22, QLabel#label_26, QLabel#label_31, QLabel#label_32,
QLabel#label_35, QLabel#label_37, QLabel#label_41, QLabel#label_48 {
    color: #F4D9D0;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.4px;
    padding: 5px 0px;
}

/* Image/volume rendering areas */
QFrame#frameReco_coronal, QFrame#frameReco_sagittal, QFrame#frameReco_axial,
QFrame#frame_visuBrain, QFrame#frame_1_ObliqueSlice, QFrame#frame_2_ObliqueSlice,
QFrame#to_complete {
    background-color: #03040A;
    border: 1px solid #242735;
    border-radius: 10px;
}

/* Secondary cards/panels */
QFrame#frame_6, QFrame#frame_18, QFrame#frame_19, QFrame#frame_23,
QFrame#frame_24, QFrame#frame_20, QFrame#frame_21, QFrame#frame_22,
QFrame#frame_25, QFrame#frame_26, QFrame#frame_27 {
    background-color: #0E1018;
    border: 1px solid #252834;
    border-radius: 12px;
}

/* ---------- Inputs ---------- */
QLineEdit, QComboBox, QSpinBox, QDoubleSpinBox {
    color: #F2F2F5;
    background-color: #151720;
    border: 1px solid #2B2D38;
    border-radius: 8px;
    min-height: 33px;
    padding: 0px 10px;
    selection-background-color: #FF487D;
    selection-color: white;
}

QLineEdit:hover, QComboBox:hover, QSpinBox:hover, QDoubleSpinBox:hover {
    border: 1px solid #3A3D4A;
}

QLineEdit:focus, QComboBox:focus, QSpinBox:focus, QDoubleSpinBox:focus {
    border: 1px solid #FF487D;
    background-color: #181A24;
}

QComboBox::drop-down {
    border: none;
    width: 28px;
    background-color: #1D1F29;
    border-top-right-radius: 7px;
    border-bottom-right-radius: 7px;
}

QComboBox QAbstractItemView {
    color: #F2F2F5;
    background-color: #10121A;
    border: 1px solid #FF487D;
    selection-background-color: #3A2132;
    selection-color: white;
    outline: none;
}

/* ---------- Buttons ---------- */
QPushButton {
    color: #F2F2F5;
    background-color: #17181F;
    border: 1px solid #2B2D38;
    border-radius: 9px;
    min-height: 37px;
    padding: 0px 14px;
    font-size: 12px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #20222B;
    border: 1px solid #FF487D;
}

QPushButton:pressed {
    background-color: #13151C;
    border: 1px solid #FF487D;
}

QPushButton:disabled {
    color: #636672;
    background-color: #101119;
    border: 1px solid #1C1E28;
}

QPushButton#btnReco_estimate,
QPushButton#Export_Coordinates_1,
QPushButton#Export_Coordinates_2,
QPushButton#Export_Coordinates_3 {
    color: white;
    border: none;
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #FF8000,
        stop:1 #FF00A0
    );
}

QPushButton#btnReco_estimate:hover,
QPushButton#Export_Coordinates_1:hover,
QPushButton#Export_Coordinates_2:hover,
QPushButton#Export_Coordinates_3:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #FF922B,
        stop:1 #FF33B8
    );
}

/* ---------- Check boxes ---------- */
QCheckBox {
    color: #D8DAE4;
    spacing: 8px;
    font-size: 12px;
}
QCheckBox::indicator {
    width: 16px;
    height: 16px;
    background-color: #151720;
    border: 1px solid #353844;
    border-radius: 4px;
}
QCheckBox::indicator:hover {
    border: 1px solid #FF487D;
}
QCheckBox::indicator:checked {
    border: 1px solid #FF487D;
    background-color: #151720;
    image: url(resources/images/neuxelec_checkbox_cross.svg);
}
QCheckBox::indicator:checked:hover {
    border: 1px solid #FF487D;
    background-color: #181A24;
    image: url(resources/images/neuxelec_checkbox_cross.svg);
}
QCheckBox:disabled { color: #636672; }
QCheckBox::indicator:disabled {
    background-color: #10121A;
    border: 1px solid #252834;
}
QCheckBox::indicator:checked:disabled {
    image: url(resources/images/neuxelec_checkbox_cross.svg);
    border: 1px solid #555967;
}

/* ---------- Sliders ---------- */
QSlider::groove:horizontal {
    height: 5px;
    background-color: #242733;
    border: none;
    border-radius: 3px;
}
QSlider::sub-page:horizontal {
    background-color: #F2F2F5;
    border: none;
    border-radius: 3px;
}
QSlider::add-page:horizontal {
    background-color: #242733;
    border: none;
    border-radius: 3px;
}
QSlider::handle:horizontal {
    background-color: #F2F2F5;
    border: 1px solid #D6D8E2;
    width: 14px;
    height: 14px;
    margin: -6px 0px;
    border-radius: 8px;
}
QSlider::handle:horizontal:hover {
    border: 1px solid #FFFFFF;
}
QSlider::handle:horizontal:pressed {
    border: 2px solid #FF487D;
}
QSlider::groove:vertical {
    width: 5px;
    background-color: #242733;
    border: none;
    border-radius: 3px;
}
QSlider::sub-page:vertical {
    background-color: #F2F2F5;
    border: none;
    border-radius: 3px;
}
QSlider::add-page:vertical {
    background-color: #242733;
    border: none;
    border-radius: 3px;
}
QSlider::handle:vertical {
    background-color: #F2F2F5;
    border: 1px solid #D6D8E2;
    width: 14px;
    height: 14px;
    margin: 0px -6px;
    border-radius: 8px;
}
QSlider::handle:vertical:hover {
    border: 1px solid #FFFFFF;
}
QSlider::handle:vertical:pressed {
    border: 2px solid #FF487D;
}

/* ---------- Shared electrode trees ---------- */
QTreeWidget {
    color: #F2F2F5;
    background-color: #0B0D14;
    alternate-background-color: #10121A;
    border: 1px solid #252834;
    border-radius: 10px;
    outline: none;
    padding: 5px;
}
QTreeWidget::item {
    min-height: 27px;
    border-radius: 6px;
    padding-left: 4px;
}
QTreeWidget::item:hover {
    background-color: #171A24;
    border: 1px solid #FF487D;
}
QTreeWidget::item:selected {
    color: white;
    background-color: #382030;
    border: 1px solid #FF487D;
}
QHeaderView::section {
    color: #CFCFD6;
    background-color: #141620;
    border: none;
    border-bottom: 1px solid #252834;
    padding: 7px;
    font-weight: 600;
}

/* ---------- Scroll bars ---------- */
QScrollBar:vertical {
    background-color: #111218;
    width: 12px;
    margin: 4px 2px 4px 2px;
    border: none;
    border-radius: 6px;
}
QScrollBar::handle:vertical {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #FF8000,
        stop:1 #FF00A0
    );
    border-radius: 5px;
    min-height: 25px;
}
QScrollBar:horizontal {
    background-color: #111218;
    height: 12px;
    margin: 2px 4px 2px 4px;
    border: none;
    border-radius: 6px;
}
QScrollBar::handle:horizontal {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #FF8000,
        stop:1 #FF00A0
    );
    border-radius: 5px;
    min-width: 25px;
}
QScrollBar::add-line, QScrollBar::sub-line {
    width: 0px;
    height: 0px;
    border: none;
    background: transparent;
}
QScrollBar::add-page, QScrollBar::sub-page {
    background: transparent;
}

QToolTip {
    color: #F2F2F5;
    background-color: #10121A;
    border: 1px solid #FF487D;
    border-radius: 6px;
    padding: 6px;
}

/* ===============================================================
   Files &amp; Coregistration workflow page
   =============================================================== */
QWidget#pageFiles, QWidget#filesWorkflowContent, QScrollArea#filesWorkflowScrollArea {
    background-color: #070810;
    border: none;
}
QScrollArea#filesWorkflowScrollArea QScrollBar:vertical {
    background-color: #11131B;
    width: 12px;
    margin: 4px 2px 4px 2px;
    border: none;
    border-radius: 6px;
}
QScrollArea#filesWorkflowScrollArea QScrollBar::handle:vertical {
    min-height: 26px;
    border-radius: 6px;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #FF8000, stop:1 #FF00A0);
}
QScrollArea#filesWorkflowScrollArea QScrollBar::add-line:vertical,
QScrollArea#filesWorkflowScrollArea QScrollBar::sub-line:vertical {
    height: 0px; background: transparent; border: none;
}
QLabel[uiRole=&quot;pageTitle&quot;] {
    color: #F5E6E2;
    font-size: 22px;
    font-weight: 600;
    letter-spacing: 1.5px;
}
QLabel[uiRole=&quot;pageSubtitle&quot;] {
    color: #8D919F;
    font-size: 12px;
    padding-bottom: 6px;
}
QFrame[workflowCard=&quot;true&quot;] {
    background-color: #0D0F17;
    border: 1px solid #20232F;
    border-radius: 16px;
}
QLabel[uiRole=&quot;sectionTitle&quot;] {
    color: #F4D9D0;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 1px;
}
QLabel[uiRole=&quot;sectionSubtitle&quot;] {
    color: #7F8494;
    font-size: 11px;
    padding-bottom: 4px;
}
QLabel[uiRole=&quot;microLabel&quot;] {
    color: #717786;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
}
QFrame[fileCell=&quot;true&quot;] { background: transparent; border: none; }
QPushButton[uiRole=&quot;loadFile&quot;] {
    color: #E7E8EE;
    background-color: #12141C;
    border: 1px solid #343844;
    border-radius: 10px;
    min-height: 42px;
    padding: 0px 10px;
    font-size: 12px;
    font-weight: 600;
}
QPushButton[uiRole=&quot;loadFile&quot;]:hover {
    background-color: #151720;
    border: 1px solid #FF487D;
}
QPushButton[uiRole=&quot;loadFile&quot;][loaded=&quot;true&quot;] {
    color: white;
    border: none;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #FF8000, stop:1 #FF00A0);
}
QPushButton[uiRole=&quot;loadFile&quot;][loaded=&quot;true&quot;]:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #FF922B, stop:1 #FF33B8);
}
QLineEdit[uiRole=&quot;pathLabel&quot;] {
    color: #858A98;
    background-color: transparent;
    border: none;
    padding: 0px 4px;
    font-size: 10px;
}
QLineEdit[uiRole=&quot;pathLabel&quot;][hasFile=&quot;true&quot;] { color: #CDD0DA; }
QFrame#coregReferenceBox {
    background-color: #11131B;
    border: 1px solid #252936;
    border-radius: 10px;
}
QCheckBox[uiRole=&quot;referenceCheck&quot;] {
    color: #707583;
    font-size: 12px;
    font-weight: 600;
    spacing: 8px;
}
QCheckBox[uiRole=&quot;referenceCheck&quot;][referenceLoaded=&quot;true&quot;] {
    color: #F5F5F8;
    border: none;
    border-radius: 8px;
    padding: 5px 10px;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #FF8000, stop:1 #FF00A0);
}
QCheckBox[uiRole=&quot;referenceCheck&quot;][referenceLoaded=&quot;true&quot;]::indicator {
    background-color: rgba(255,255,255,42);
    border: 1px solid rgba(255,255,255,130);
}
QCheckBox[uiRole=&quot;referenceCheck&quot;][referenceLoaded=&quot;true&quot;]::indicator:checked {
    background-color: white;
    border: 1px solid white;
}
QCheckBox[uiRole=&quot;modalityCheck&quot;] {
    color: #C8CBD5;
    font-size: 12px;
    font-weight: 500;
    spacing: 8px;
    padding: 5px 7px;
}
QCheckBox[uiRole=&quot;modalityCheck&quot;]:disabled { color: #555A68; }
QCheckBox[uiRole=&quot;modalityCheck&quot;]::indicator:checked {
    border: 1px solid #FF487D;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #FF8000, stop:1 #FF00A0);
}
QPushButton[uiRole=&quot;workflowAction&quot;] {
    color: #E7E8EE;
    background-color: #12141C;
    border: 1px solid #343844;
    border-radius: 10px;
    min-height: 42px;
    font-size: 12px;
    font-weight: 600;
}
QPushButton[uiRole=&quot;workflowAction&quot;]:hover:enabled {
    border: 1px solid #FF487D;
    background-color: #151720;
}
QPushButton[uiRole=&quot;reviewAction&quot;] {
    color: #707583;
    background-color: #10121A;
    border: 1px solid #252936;
    border-radius: 10px;
    min-height: 42px;
    font-size: 12px;
    font-weight: 600;
}
QPushButton[uiRole=&quot;reviewAction&quot;][completed=&quot;true&quot;] {
    color: white;
    border: none;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #FF8000, stop:1 #FF00A0);
}
QPushButton[uiRole=&quot;reviewAction&quot;][completed=&quot;true&quot;]:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #FF922B, stop:1 #FF33B8);
}
QPushButton[uiRole=&quot;saveAction&quot;] {
    color: #636977;
    background-color: #10121A;
    border: 1px solid #252936;
    border-radius: 10px;
    min-height: 42px;
    font-size: 12px;
    font-weight: 600;
}
QPushButton[uiRole=&quot;saveAction&quot;]:enabled {
    color: #F1F2F6;
    background-color: #12141C;
    border: 1px solid #FF487D;
}
QPushButton[uiRole=&quot;saveAction&quot;]:enabled:hover { background-color: #1A1620; }
QProgressBar[uiRole=&quot;workflowProgress&quot;] {
    color: #F2F2F5;
    background-color: #161923;
    border: 1px solid #252936;
    border-radius: 9px;
    text-align: center;
    min-height: 20px;
    font-size: 10px;
    font-weight: 600;
}
QProgressBar[uiRole=&quot;workflowProgress&quot;]::chunk {
    border-radius: 8px;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #FF8000, stop:1 #FF00A0);
}

QPushButton[uiRole=&quot;saveAllAction&quot;] {
    color: #817B86;
    background-color: #15131B;
    border: 1px solid #583047;
    border-radius: 12px;
    min-height: 48px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.5px;
}
QPushButton[uiRole=&quot;saveAllAction&quot;]:enabled {
    color: white;
    border: none;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #FF8000, stop:1 #FF00A0);
}
QPushButton[uiRole=&quot;saveAllAction&quot;]:enabled:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #FF922B, stop:1 #FF33B8);
}
QPushButton[uiRole=&quot;saveAllAction&quot;]:enabled:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #E56F00, stop:1 #E0008C);
}

/* ===============================================================
   RECONSTRUCTION PAGE - NeuXelec dark workflow refinement
   =============================================================== */
QWidget#pageReconstruction {
    background-color: #06070D;
    border: none;
}

/* Remove native white/pointed host frames around all three slices. */
QWidget#pageReconstruction QFrame#frame_7,
QWidget#pageReconstruction QFrame#frame_5 {
    background-color: transparent;
    border: none;
    border-radius: 0px;
}

QWidget#pageReconstruction QLabel#label_2,
QWidget#pageReconstruction QLabel#label_3,
QWidget#pageReconstruction QLabel#label_4 {
    color: #F4D9D0;
    background-color: #0E1018;
    border: 1px solid #252834;
    border-bottom: none;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    min-height: 30px;
    padding: 6px 12px 4px 12px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
}

/* The rendering host remains plain dark: no visible corner spikes. */
QWidget#pageReconstruction QFrame#frameReco_coronal,
QWidget#pageReconstruction QFrame#frameReco_sagittal,
QWidget#pageReconstruction QFrame#frameReco_axial {
    background-color: #03040A;
    border: none;
    border-radius: 0px;
}

/* Visual separation is carried by the title rather than a white frame. */
QWidget#pageReconstruction QScrollBar#scrollReco_coronal,
QWidget#pageReconstruction QScrollBar#scrollReco_sagittal,
QWidget#pageReconstruction QScrollBar#scrollReco_axial {
    background-color: #10121A;
    border: none;
}

/* Electrode parameter card: readable and intentionally compact. */
QWidget#pageReconstruction QFrame#frame_25 {
    background-color: #0E1018;
    border: 1px solid #252834;
    border-radius: 12px;
}

QWidget#pageReconstruction QScrollArea#scrollArea,
QWidget#pageReconstruction QWidget#scrollAreaWidgetContents {
    background-color: transparent;
    border: none;
}

QWidget#pageReconstruction QLabel#label_5,
QWidget#pageReconstruction QLabel#label_6 {
    color: #F4D9D0;
    background-color: transparent;
    border: none;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1px;
    padding-bottom: 4px;
}

QWidget#pageReconstruction QLabel#label_7,
QWidget#pageReconstruction QLabel#label_9,
QWidget#pageReconstruction QLabel#label_10,
QWidget#pageReconstruction QLabel#label_11,
QWidget#pageReconstruction QLabel#label_15,
QWidget#pageReconstruction QLabel#Reference,
QWidget#pageReconstruction QLabel#label_19 {
    color: #A8ABBA;
    background-color: transparent;
    border: none;
    font-size: 11px;
    font-weight: 500;
}

QWidget#pageReconstruction QLabel#label_12,
QWidget#pageReconstruction QLabel#label_13,
QWidget#pageReconstruction QLabel#label_14,
QWidget#pageReconstruction QLabel#label_16,
QWidget#pageReconstruction QLabel#label_17,
QWidget#pageReconstruction QLabel#label_18 {
    color: #A8ABBA;
    background-color: transparent;
    border: none;
    font-size: 11px;
    font-weight: 600;
}

/* Compact Pick and coordinate alignment. */
