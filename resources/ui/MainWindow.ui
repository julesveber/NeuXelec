/* ===============================================================
   FILES LOAD/SAVE STATES + REGULAR NAVIGATION - final refinement
   =============================================================== */

/* Loaded inputs: no gradient, only a permanent validation outline. */
QPushButton[uiRole=&quot;loadFile&quot;][loaded=&quot;true&quot;] {
    color: #F1F2F6;
    background-color: #12141C;
    border: 1px solid #FF487D;
}
QPushButton[uiRole=&quot;loadFile&quot;][loaded=&quot;true&quot;]:hover {
    color: white;
    background-color: #151720;
    border: 1px solid #FF487D;
}

/* Validated outputs remain neutral until hovered or actually saved. */
QPushButton[uiRole=&quot;saveAction&quot;]:enabled {
    color: #F1F2F6;
    background-color: #12141C;
    border: 1px solid #343844;
}
QPushButton[uiRole=&quot;saveAction&quot;]:enabled:hover {
    color: white;
    background-color: #171923;
    border: 1px solid #FF487D;
}
QPushButton[uiRole=&quot;saveAction&quot;][saved=&quot;true&quot;],
QPushButton[uiRole=&quot;saveAction&quot;][saved=&quot;true&quot;]:enabled {
    color: #F1F2F6;
    background-color: #12141C;
    border: 1px solid #FF487D;
}
QPushButton[uiRole=&quot;saveAction&quot;][saved=&quot;true&quot;]:hover {
    color: white;
    background-color: #171923;
    border: 1px solid #FF487D;
}

