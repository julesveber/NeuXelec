}
QWidget#page3DView QLabel#lbl3DSurfacesCard,
QWidget#page3DView QLabel#lbl3DElectrodesCard,
QWidget#page3DView QLabel#lbl3DSlicesCard,
QWidget#page3DView QLabel#lbl3DMRICard,
QWidget#page3DView QLabel#lbl3DCTCard,
QWidget#page3DView QLabel#lbl3DPETCard,
QWidget#page3DView QLabel#lbl3DSISCOMCard,
QWidget#page3DView QLabel#lbl3DParcellationCard {
