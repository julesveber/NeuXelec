}

QWidget#page3DView QFrame#frame_2 {
    background-color: transparent;
    border: none;
}
QWidget#page3DView QFrame#card3DSlices QPushButton {
    color: #D8DAE4;
    background-color: #151720;
    border: 1px solid #2B2D38;
    border-radius: 8px;
    min-height: 34px;
    padding: 0px 10px;
    font-size: 11px;
    font-weight: 600;
}
QWidget#page3DView QFrame#card3DSlices QPushButton:hover {
    color: white;
    border: 1px solid #FF487D;
}

QWidget#page3DView QSpinBox,
QWidget#page3DView QDoubleSpinBox {
    color: #F2F2F5;
    background-color: #151720;
    border: 1px solid #2B2D38;
    border-radius: 7px;
    min-height: 30px;
    padding: 3px 25px 3px 8px;
    selection-background-color: #FF487D;
    selection-color: white;
}
QWidget#page3DView QSpinBox:hover,
QWidget#page3DView QDoubleSpinBox:hover {
    border: 1px solid #3B3D48;
}
QWidget#page3DView QSpinBox:focus,
QWidget#page3DView QDoubleSpinBox:focus {
    border: 1px solid #FF487D;
    background-color: #181A24;
}
QWidget#page3DView QSpinBox::up-button,
QWidget#page3DView QDoubleSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 19px;
    background-color: #1D1F29;
    border: none;
    border-left: 1px solid #2B2D38;
    border-bottom: 1px solid #2B2D38;
    border-top-right-radius: 6px;
    margin: 1px 1px 0px 0px;
}
QWidget#page3DView QSpinBox::down-button,
QWidget#page3DView QDoubleSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 19px;
    background-color: #1D1F29;
    border: none;
    border-left: 1px solid #2B2D38;
    border-bottom-right-radius: 6px;
    margin: 0px 1px 1px 0px;
}
QWidget#page3DView QSpinBox::up-button:hover,
QWidget#page3DView QDoubleSpinBox::up-button:hover,
QWidget#page3DView QSpinBox::down-button:hover,
QWidget#page3DView QDoubleSpinBox::down-button:hover {
    background-color: #282A34;
}
QWidget#page3DView QSpinBox::up-arrow,
QWidget#page3DView QDoubleSpinBox::up-arrow {
    image: url(resources/images/spin_up.svg);
    width: 9px;
    height: 6px;
}
QWidget#page3DView QSpinBox::down-arrow,
QWidget#page3DView QDoubleSpinBox::down-arrow {
    image: url(resources/images/spin_down.svg);
    width: 9px;
    height: 6px;
}

QWidget#page3DView QScrollBar:vertical {
    background-color: #11131B;
    border: none;
    border-radius: 5px;
    width: 10px;
    margin: 2px;
}
QWidget#page3DView QScrollBar::handle:vertical {
    min-height: 25px;
    border: none;
    border-radius: 5px;
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #FF8000,
        stop:1 #FF00A0
    );
}
QWidget#page3DView QScrollBar::add-line:vertical,
QWidget#page3DView QScrollBar::sub-line:vertical {
    height: 0px;
    background-color: transparent;
    border: none;
}
QWidget#page3DView QScrollBar::add-page:vertical,
QWidget#page3DView QScrollBar::sub-page:vertical {
    background-color: transparent;
}


/* ===============================================================
   MAIN WINDOW - CUSTOM CHROME AND SIDEBAR LOGO
   =============================================================== */
QWidget#Form {
    background-color: #06070D;
    border: 1px solid #FF487D;
    border-radius: 16px;
}
QWidget#Form[maximized=&quot;true&quot;] {
    border: none;
    border-radius: 0px;
}
QFrame#customTitleBar {
    background-color: #06070D;
    border: none;
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
}
QWidget#Form[maximized=&quot;true&quot;] QFrame#customTitleBar {
    border-radius: 0px;
}
QLabel#lbl_windowTitle {
    color: #757A8C;
    background-color: transparent;
    border: none;
}
QPushButton[uiRole=&quot;windowControl&quot;] {
    color: #D8DAE4;
    background-color: transparent;
    border: 1px solid transparent;
    border-radius: 8px;
    min-width: 38px;
    max-width: 38px;
    min-height: 34px;
    max-height: 34px;
    font-size: 17px;
    font-weight: 500;
    padding: 0px;
}
QPushButton#btn_window_minimize:hover,
QPushButton#btn_window_maximize:hover {
    color: white;
    border: 1px solid #FF487D;
    background-color: #171923;
}
QPushButton#btn_window_close:hover {
    color: white;
    border: none;
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #FF8000,
        stop:1 #FF00A0
    );
}
QPushButton[uiRole=&quot;windowControl&quot;]:pressed {
    background-color: #252834;
}
QLabel#appTitle {
    color: transparent;
    background-color: transparent;
    border: none;
    padding: 0px;
    margin: 0px;
}
QLabel#appSubtitle {
    color: #8B8FA0;
    background-color: transparent;
    border: none;
    padding-top: 2px;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1px;
}


/* ===============================================================
   FILES / COREGISTRATION - CLINICAL STEP WORKFLOW FINAL STATES
   =============================================================== */
QWidget#pageFiles QLabel#cardFilesToLoadTitle,
QWidget#pageFiles QLabel#cardCoregistrationTitle,
QWidget#pageFiles QLabel#cardBrainMaskTitle,
QWidget#pageFiles QLabel#cardSISCOMTitle,
QWidget#pageFiles QLabel#cardFilesToSaveTitle {
    color: #F4D9D0;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
}
QWidget#pageFiles QLabel#cardFilesToLoadSubtitle,
QWidget#pageFiles QLabel#cardCoregistrationSubtitle,
QWidget#pageFiles QLabel#cardBrainMaskSubtitle,
QWidget#pageFiles QLabel#cardSISCOMSubtitle,
QWidget#pageFiles QLabel#cardFilesToSaveSubtitle {
    color: #9599AA;
    font-size: 10px;
}

/* Loaded inputs remain dark; their pink border confirms availability. */
QWidget#pageFiles QPushButton[uiRole=&quot;loadFile&quot;][loaded=&quot;true&quot;] {
    color: #F2F2F5;
    background-color: #12141C;
    border: 1px solid #FF487D;
}
QWidget#pageFiles QPushButton[uiRole=&quot;loadFile&quot;][loaded=&quot;true&quot;]:hover {
    color: white;
    background-color: #171923;
    border: 1px solid #FF6BA0;
}

/* Reviewed/validated actions remain dark with a persistent pink outline. */
QWidget#pageFiles QPushButton[uiRole=&quot;reviewAction&quot;][completed=&quot;true&quot;] {
    color: #F2F2F5;
    background-color: #12141C;
    border: 1px solid #FF487D;
}
QWidget#pageFiles QPushButton[uiRole=&quot;reviewAction&quot;][completed=&quot;true&quot;]:hover {
    color: white;
    background-color: #171923;
    border: 1px solid #FF487D;
}

/* Individual output buttons never receive the gradient. */
QWidget#pageFiles QPushButton[uiRole=&quot;saveAction&quot;]:enabled {
    color: #F1F2F6;
    background-color: #12141C;
    border: 1px solid #343844;
}
QWidget#pageFiles QPushButton[uiRole=&quot;saveAction&quot;]:enabled:hover {
    color: white;
    background-color: #171923;
    border: 1px solid #FF487D;
}
QWidget#pageFiles QPushButton[uiRole=&quot;saveAction&quot;][saved=&quot;true&quot;],
QWidget#pageFiles QPushButton[uiRole=&quot;saveAction&quot;][saved=&quot;true&quot;]:enabled {
    color: #F1F2F6;
    background-color: #12141C;
    border: 1px solid #FF487D;
}

/* Save all is deliberately the sole gradient action once export is possible. */
QWidget#pageFiles QPushButton[uiRole=&quot;saveAllAction&quot;]:enabled {
    color: white;
    border: none;
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #FF8000,
        stop:1 #FF00A0
    );
}
QWidget#pageFiles QPushButton[uiRole=&quot;saveAllAction&quot;]:enabled:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #FF922B,
        stop:1 #FF33B8
    );
}

/* Progress is gradient, but softened to 75 percent opacity. */
QWidget#pageFiles QProgressBar[uiRole=&quot;workflowProgress&quot;]::chunk {
    border-radius: 8px;
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 rgba(255, 128, 0, 191),
        stop:1 rgba(255, 0, 160, 191)
    );
}

/* ===============================================================
   OBLIQUE SLICE - ROSE OUTLINED ACTIVE TAB, NO GRADIENT
   =============================================================== */
QWidget#pageObliqueSlices QTabWidget#tabWidget QTabBar::tab {
    color: #9599AA;
    background-color: #11131B;
    border: 1px solid #252834;
    border-bottom: none;
}
QWidget#pageObliqueSlices QTabWidget#tabWidget QTabBar::tab:hover {
    color: #FF7AA2;
    background-color: #151720;
    border: 1px solid #FF487D;
    border-bottom: none;
}
QWidget#pageObliqueSlices QTabWidget#tabWidget QTabBar::tab:selected {
    color: #FF7AA2;
    background-color: #151720;
    border: 1px solid #FF487D;
    border-bottom: none;
}


/* ===============================================================
   MINIMAL FINAL CORRECTIONS - MENU TYPOGRAPHY AND T1 REFERENCE
   =============================================================== */

/* Logo placed above MULTIMODAL ELECTRODE HUB. */
QLabel#appTitle {
    background-color: transparent;
    border: none;
    padding: 0px 5px;
}

/* Same visual language as the clinical workflow section titles. */
QFrame#menu QPushButton#btn_menu_fileCoreg,
QFrame#menu QPushButton#btn_menu_reconstruction,
QFrame#menu QPushButton#btn_menu_obliqueSlice,
QFrame#menu QPushButton#btn_menu_3Dview {
    font-family: &quot;Segoe UI&quot;;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
}

/*
Step 2 - T1 is the fixed reference.
Only the checkbox indicator is highlighted after T1 is available:
the full T1 row must stay dark.
*/
QWidget#pageFiles QCheckBox[uiRole=&quot;referenceCheck&quot;][referenceLoaded=&quot;true&quot;] {
    color: #F2F2F5;
    background-color: transparent;
    border: none;
    border-radius: 0px;
    padding: 5px 0px;
}
QWidget#pageFiles QCheckBox[uiRole=&quot;referenceCheck&quot;][referenceLoaded=&quot;true&quot;]::indicator {
    border: 1px solid #FF487D;
    border-radius: 5px;
    background-color: #151720;
}
QWidget#pageFiles QCheckBox[uiRole=&quot;referenceCheck&quot;][referenceLoaded=&quot;true&quot;]::indicator:checked {
    border: 1px solid #FF487D;
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #FF8000,
        stop:1 #FF00A0
    );
}


/* Reconstruction view orientation buttons: selected = grey + persistent pink border. */
QWidget#pageReconstruction QPushButton#btn_radiologicView:hover,
QWidget#pageReconstruction QPushButton#btn_researchView:hover {
    border: 1px solid #FF487D;
}
QWidget#pageReconstruction QPushButton#btn_radiologicView:checked,
QWidget#pageReconstruction QPushButton#btn_researchView:checked,
QWidget#pageReconstruction QPushButton#btn_radiologicView:checked:hover,
QWidget#pageReconstruction QPushButton#btn_researchView:checked:hover {
    background-color: #41434A;
    border: 1px solid #FF487D;
}


/* ---------- Files/Coregistration workflow grouping ---------- */
QLabel#filesLoadGroupMRI,
QLabel#filesLoadGroupCT,
QLabel#filesLoadGroupFunctional,
QLabel#filesLoadGroupDerived,
QLabel#filesLoadGroupLabels,
QLabel#filesLoadGroupSurfaces {
    color: #8B8FA0;
    background-color: transparent;
    border: none;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.2px;
    padding-top: 8px;
    padding-bottom: 2px;
}

QFrame#cardFilesToLoad QLabel#cardFilesToLoadSubtitle,
QFrame#cardCoregistration QLabel#cardCoregistrationSubtitle,
QFrame#cardBrainMask QLabel#cardBrainMaskSubtitle,
QFrame#cardSISCOM QLabel#cardSISCOMSubtitle,
QFrame#cardFilesToSave QLabel#cardFilesToSaveSubtitle {
    color: #8B8FA0;
    line-height: 130%;
}


/* ===============================================================
   FILES/COREG - requested v2 cleanup
   =============================================================== */

/* Remove the small vertical grouping strokes beside load buttons. */
QWidget#pageFiles QFrame[fileCell=&quot;true&quot;],
QFrame#btn_FilesCoreg_loadT1Cell,
QFrame#btn_FilesCoreg_loadT2Cell,
QFrame#btn_FilesCoreg_loadCTCell,
QFrame#btn_FilesCoreg_loadPETCell,
QFrame#btn_FilesCoreg_loadictalSPECTCell,
QFrame#btn_FilesCoreg_loadinterictalSPECTCell,
QFrame#btn_FilesCoreg_loadSISCOMCell,
QFrame#btn_FilesCoreg_loadParcel1Cell,
QFrame#btn_FilesCoreg_loadParcel2Cell,
QFrame#btn_FilesCoreg_lhpialCell,
QFrame#btn_FilesCoreg_rhpialCell,
QFrame#btn_FilesCoreg_loadBrainMaskCell {
    background-color: transparent;
    border: none;
    border-left: none;
}

/* Files/Coregistration checkboxes: checked = dark fill + pink border + white cross.
   This overrides the older gradient rules for T1 reference and modality checks. */
QWidget#pageFiles QCheckBox::indicator:checked,
QWidget#pageFiles QCheckBox[uiRole=&quot;referenceCheck&quot;]::indicator:checked,
QWidget#pageFiles QCheckBox[uiRole=&quot;referenceCheck&quot;][referenceLoaded=&quot;true&quot;]::indicator:checked,
QWidget#pageFiles QCheckBox[uiRole=&quot;modalityCheck&quot;]::indicator:checked {
    background-color: #151720;
    border: 1px solid #FF487D;
    border-radius: 5px;
    image: url(resources/images/neuxelec_checkbox_cross.svg);
}

QWidget#pageFiles QCheckBox::indicator:checked:hover,
QWidget#pageFiles QCheckBox[uiRole=&quot;referenceCheck&quot;]::indicator:checked:hover,
QWidget#pageFiles QCheckBox[uiRole=&quot;referenceCheck&quot;][referenceLoaded=&quot;true&quot;]::indicator:checked:hover,
QWidget#pageFiles QCheckBox[uiRole=&quot;modalityCheck&quot;]::indicator:checked:hover {
    background-color: #181A24;
    border: 1px solid #FF487D;
    image: url(resources/images/neuxelec_checkbox_cross.svg);
}

QWidget#pageFiles QCheckBox::indicator:checked:disabled,
QWidget#pageFiles QCheckBox[uiRole=&quot;referenceCheck&quot;]::indicator:checked:disabled,
QWidget#pageFiles QCheckBox[uiRole=&quot;modalityCheck&quot;]::indicator:checked:disabled {
    background-color: rgba(21, 23, 32, 130);
    border: 1px solid rgba(255, 72, 125, 125);
    image: url(resources/images/neuxelec_checkbox_cross.svg);
}

/* Slider inactive state: this is applied when the corresponding modality
   controls are disabled by Python after the modality checkbox is unchecked. */
QSlider::groove:horizontal:disabled {
    background-color: rgba(36, 39, 51, 125);
    border: none;
    border-radius: 3px;
}
QSlider::sub-page:horizontal:disabled {
    background-color: rgba(242, 242, 245, 125);
    border: none;
    border-radius: 3px;
}
QSlider::add-page:horizontal:disabled {
    background-color: rgba(36, 39, 51, 125);
    border: none;
    border-radius: 3px;
}
QSlider::handle:horizontal:disabled {
    background-color: rgba(242, 242, 245, 125);
    border: 1px solid rgba(214, 216, 226, 125);
    width: 14px;
    height: 14px;
    margin: -6px 0px;
    border-radius: 8px;
}

QSlider::groove:vertical:disabled {
    background-color: rgba(36, 39, 51, 125);
    border: none;
    border-radius: 3px;
}
QSlider::sub-page:vertical:disabled {
    background-color: rgba(242, 242, 245, 125);
    border: none;
    border-radius: 3px;
}
QSlider::add-page:vertical:disabled {
    background-color: rgba(36, 39, 51, 125);
    border: none;
    border-radius: 3px;
}
QSlider::handle:vertical:disabled {
    background-color: rgba(242, 242, 245, 125);
    border: 1px solid rgba(214, 216, 226, 125);
    width: 14px;
    height: 14px;
    margin: 0px -6px;
    border-radius: 8px;
}


/* ============================================================
   FINAL REQUESTED OVERRIDES - menu, reconstruction scrolls, grid
   ============================================================ */

/* Left menu: active page = grey fill + persistent pink outline, no gradient. */
QFrame#menu QPushButton#btn_menu_fileCoreg,
QFrame#menu QPushButton#btn_menu_reconstruction,
QFrame#menu QPushButton#btn_menu_obliqueSlice,
QFrame#menu QPushButton#btn_menu_3Dview {
    color: #F2F2F5;
    background-color: #11131B;
    border: 1px solid #2B2D38;
    border-radius: 10px;
    padding: 0px;
    text-align: center;
    min-height: 48px;
    max-height: 48px;
    font-size: 12px;
    font-weight: 600;
}
QFrame#menu QPushButton#btn_menu_fileCoreg:hover,
QFrame#menu QPushButton#btn_menu_reconstruction:hover,
QFrame#menu QPushButton#btn_menu_obliqueSlice:hover,
QFrame#menu QPushButton#btn_menu_3Dview:hover {
    color: white;
    background-color: #171923;
    border: 1px solid #FF487D;
}
QFrame#menu QPushButton#btn_menu_fileCoreg:checked,
QFrame#menu QPushButton#btn_menu_reconstruction:checked,
QFrame#menu QPushButton#btn_menu_obliqueSlice:checked,
QFrame#menu QPushButton#btn_menu_3Dview:checked,
QFrame#menu QPushButton#btn_menu_fileCoreg:checked:hover,
QFrame#menu QPushButton#btn_menu_reconstruction:checked:hover,
QFrame#menu QPushButton#btn_menu_obliqueSlice:checked:hover,
QFrame#menu QPushButton#btn_menu_3Dview:checked:hover {
    color: white;
    background-color: #41434A;
    border: 1px solid #FF487D;
}

/* Reconstruction page: all visible scroll controls must read as scrollbars,
   not as color scales. */
QWidget#pageReconstruction QScrollBar:vertical {
    background-color: transparent;
    border: none;
    width: 10px;
    margin: 5px 2px 5px 2px;
}
QWidget#pageReconstruction QScrollBar::handle:vertical {
    min-height: 28px;
    background-color: #3B3E48;
    border: 1px solid #FF487D;
    border-radius: 5px;
}
QWidget#pageReconstruction QScrollBar::handle:vertical:hover {
    background-color: #4A4D58;
    border: 1px solid #FF6B98;
}
QWidget#pageReconstruction QScrollBar::add-line:vertical,
QWidget#pageReconstruction QScrollBar::sub-line:vertical {
    height: 0px;
    border: none;
    background: transparent;
}
QWidget#pageReconstruction QScrollBar::add-page:vertical,
QWidget#pageReconstruction QScrollBar::sub-page:vertical {
    background: transparent;
    border: none;
}

/* Oblique slice plane scrollbars too: grey with pink outline, not gradient. */
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_1st,
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_2nd {
    background-color: transparent;
    border: none;
    width: 10px;
    margin: 5px 2px 5px 2px;
}
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_1st::handle:vertical,
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_2nd::handle:vertical {
    min-height: 28px;
    background-color: #3B3E48;
    border: 1px solid #FF487D;
    border-radius: 5px;
}
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_1st::add-line:vertical,
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_1st::sub-line:vertical,
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_2nd::add-line:vertical,
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_2nd::sub-line:vertical {
    height: 0px;
    border: none;
    background: transparent;
}
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_1st::add-page:vertical,
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_1st::sub-page:vertical,
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_2nd::add-page:vertical,
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_2nd::sub-page:vertical {
    background: transparent;
    border: none;
}

/* Remove native blue selection/focus artefacts in electrode trees. */
QTreeWidget#tv_Electrodes {
    outline: none;
    selection-background-color: transparent;
    selection-color: #F2F2F5;
}
QTreeWidget#tv_Electrodes::item:selected,
QTreeWidget#tv_Electrodes::item:selected:active,
QTreeWidget#tv_Electrodes::item:selected:!active {
    background-color: transparent;
    border: none;
}
QTreeWidget#tv_Electrodes::branch:selected,
QTreeWidget#tv_Electrodes::branch:selected:active,
QTreeWidget#tv_Electrodes::branch:selected:!active,
QTreeWidget#tv_Electrodes::branch:open:has-children:selected,
QTreeWidget#tv_Electrodes::branch:closed:has-children:selected {
    background-color: transparent;
    border: none;
}

/* Reconstruction grid cells: keep a clean, symmetric 2 × 2 feel. */
QWidget#pageReconstruction QFrame#frame_25,
QWidget#pageReconstruction QFrame#frameReco_coronal,
QWidget#pageReconstruction QFrame#frameReco_sagittal,
QWidget#pageReconstruction QFrame#frameReco_axial {
    min-width: 0px;
    min-height: 0px;
}

/* ===============================================================
   GLOBAL OVERRIDE - SCROLLBARS GRAY WITH PINK OUTLINE ON ALL PAGES
   Only scrollbar visuals are overridden here.
   =============================================================== */

/* Generic scrollbar tracks */
QScrollBar:vertical,
QScrollArea QScrollBar:vertical {
    background-color: transparent;
    border: none;
    width: 10px;
    margin: 5px 2px 5px 2px;
    border-radius: 5px;
}

QScrollBar:horizontal,
QScrollArea QScrollBar:horizontal {
    background-color: transparent;
    border: none;
    height: 10px;
    margin: 2px 5px 2px 5px;
    border-radius: 5px;
}

/* Generic scrollbar handles */
QScrollBar::handle:vertical,
QScrollArea QScrollBar::handle:vertical {
    min-height: 28px;
    background-color: #3B3E48;
    border: 1px solid #FF487D;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover,
QScrollArea QScrollBar::handle:vertical:hover {
    background-color: #4A4D58;
    border: 1px solid #FF6B98;
}

QScrollBar::handle:horizontal,
QScrollArea QScrollBar::handle:horizontal {
    min-width: 28px;
    background-color: #3B3E48;
    border: 1px solid #FF487D;
    border-radius: 5px;
}

QScrollBar::handle:horizontal:hover,
QScrollArea QScrollBar::handle:horizontal:hover {
    background-color: #4A4D58;
    border: 1px solid #FF6B98;
}

/* Remove native arrows/pages everywhere */
QScrollBar::add-line,
QScrollBar::sub-line,
QScrollArea QScrollBar::add-line,
QScrollArea QScrollBar::sub-line {
    width: 0px;
    height: 0px;
    border: none;
    background-color: transparent;
}

QScrollBar::add-page,
QScrollBar::sub-page,
QScrollArea QScrollBar::add-page,
QScrollArea QScrollBar::sub-page {
    background-color: transparent;
    border: none;
}

/* Higher-specificity overrides for pages that already had dedicated scrollbar rules. */
QScrollArea#filesWorkflowScrollArea QScrollBar:vertical,
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_1st:vertical,
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_2nd:vertical,
QWidget#page3DView QScrollArea#scrollArea_4 QScrollBar:vertical,
QWidget#page3DView QScrollArea#scrollArea_5 QScrollBar:vertical,
QWidget#page3DView QScrollBar:vertical,
QWidget#pageReconstruction QScrollBar:vertical {
    background-color: transparent;
    border: none;
    width: 10px;
    margin: 5px 2px 5px 2px;
    border-radius: 5px;
}

QScrollArea#filesWorkflowScrollArea QScrollBar::handle:vertical,
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_1st::handle:vertical,
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_2nd::handle:vertical,
QWidget#page3DView QScrollArea#scrollArea_4 QScrollBar::handle:vertical,
QWidget#page3DView QScrollArea#scrollArea_5 QScrollBar::handle:vertical,
QWidget#page3DView QScrollBar::handle:vertical,
QWidget#pageReconstruction QScrollBar::handle:vertical {
    min-height: 28px;
    background-color: #3B3E48;
    border: 1px solid #FF487D;
    border-radius: 5px;
}

QScrollArea#filesWorkflowScrollArea QScrollBar::handle:vertical:hover,
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_1st::handle:vertical:hover,
QWidget#pageObliqueSlices QScrollBar#verticalScrollBar_2nd::handle:vertical:hover,
QWidget#page3DView QScrollArea#scrollArea_4 QScrollBar::handle:vertical:hover,
QWidget#page3DView QScrollArea#scrollArea_5 QScrollBar::handle:vertical:hover,
QWidget#page3DView QScrollBar::handle:vertical:hover,
QWidget#pageReconstruction QScrollBar::handle:vertical:hover {
    background-color: #4A4D58;
    border: 1px solid #FF6B98;
}


/* ===============================================================
   FILES / COREGISTRATION - BULK IMPORT + STATUS OVERVIEW
   =============================================================== */
QFrame#cardBulkImport, QFrame#cardFilesStatusOverview {
    background-color: #0D0F17;
    border: 1px solid #20232F;
    border-radius: 16px;
}
QFrame#cardBulkImport QPushButton[uiRole=&quot;loadFile&quot;] {
    min-height: 52px;
    font-size: 13px;
}
QFrame[uiRole=&quot;statusGroupCard&quot;] {
    background-color: #0D0F16;
    border: 1px solid #252936;
    border-radius: 12px;
}
QLabel[uiRole=&quot;statusGroupTitle&quot;] {
    color: #F4D9D0;
    background-color: transparent;
    border: none;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
}
QLabel[uiRole=&quot;statusPill&quot;] {
    color: #525764;
    font-size: 14px;
    font-weight: 900;
    padding-left: 2px;
    padding-right: 2px;
}
QLabel[uiRole=&quot;statusPill&quot;][status=&quot;loaded&quot;] { color: #3FA7FF; }
QLabel[uiRole=&quot;statusPill&quot;][status=&quot;validated&quot;] { color: #42D67A; }
QLabel[uiRole=&quot;statusPill&quot;][status=&quot;warning&quot;] { color: #3FA7FF; }
QLabel[uiRole=&quot;statusPill&quot;][status=&quot;missing&quot;] { color: #525764; }
QLabel[uiRole=&quot;statusName&quot;] {
    color: #D7D9E3;
    font-size: 11px;
    font-weight: 600;
}
QLabel[uiRole=&quot;statusText&quot;] {
    color: #737887;
    font-size: 10px;
    font-weight: 600;
}
QLabel[uiRole=&quot;statusText&quot;][status=&quot;loaded&quot;] { color: #3FA7FF; }
QLabel[uiRole=&quot;statusText&quot;][status=&quot;validated&quot;] { color: #42D67A; }
QLabel[uiRole=&quot;statusText&quot;][status=&quot;warning&quot;] { color: #3FA7FF; }
QLabel[uiRole=&quot;statusText&quot;][status=&quot;missing&quot;] { color: #737887; }

/* ===============================================================
   FILES / COREGISTRATION - exact title unification patch
   All STEP titles intentionally match LOADED DATA STATUS.
   =============================================================== */
QWidget#pageFiles QLabel#cardBulkImportTitle,
QWidget#pageFiles QLabel#cardFilesStatusOverviewTitle,
QWidget#pageFiles QLabel#cardCoregistrationTitle,
QWidget#pageFiles QLabel#cardBrainMaskTitle,
QWidget#pageFiles QLabel#cardSISCOMTitle,
QWidget#pageFiles QLabel#cardFilesToSaveTitle {
    color: #F4D9D0;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 1px;
    padding: 0px;
    margin: 0px;
    border: none;
    background-color: transparent;
}
QWidget#pageFiles QLabel#cardBulkImportSubtitle,
QWidget#pageFiles QLabel#cardFilesStatusOverviewSubtitle,
QWidget#pageFiles QLabel#cardCoregistrationSubtitle,
QWidget#pageFiles QLabel#cardBrainMaskSubtitle,
QWidget#pageFiles QLabel#cardSISCOMSubtitle,
QWidget#pageFiles QLabel#cardFilesToSaveSubtitle {
    color: #7F8494;
    font-size: 11px;
    padding-bottom: 4px;
    margin: 0px;
    border: none;
    background-color: transparent;
}

