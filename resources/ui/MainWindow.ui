}
QWidget#pageObliqueSlices QSpinBox::down-button,
QWidget#pageObliqueSlices QDoubleSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 19px;
    background-color: #1D1F29;
