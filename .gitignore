# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.Python
build/
develop-eggs/
downloads/
.installed.cfg

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# PyInstaller / Inno Setup build artifacts (regenerated from sources)
# ---------------------------------------------------------------------------
dist/
build/
installer/*.exe
*.spec.bak

# ---------------------------------------------------------------------------
# Third-party binaries and large data (obtained separately, see README)
#   - tools/ants : ANTs executables (large, third-party, platform specific)
#   - templates  : MNI templates and atlases (large NIfTI volumes)
# ---------------------------------------------------------------------------
tools/
templates/

# ---------------------------------------------------------------------------
# Patient / imaging data — must never be committed
# ---------------------------------------------------------------------------
*.nii
*.nii.gz
*.mgz
*.dcm
*.DCM
*.img
*.hdr

# ---------------------------------------------------------------------------
# Test / coverage / type-checker caches
# ---------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# IDE / OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
Thumbs.db
Desktop.ini
.DS_Store
